\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Single-DTE calibration and cross-ticker validation. \textbf  {(a)}~NVDA implied volatility smile (DTE~=~80): market calls (blue circles) and puts (coral diamonds) vs.\ the fitted model curve (solid line); the dashed vertical line marks the spot price (\$207). The four-parameter $\psi $ function captured both the put skew and smile curvature with an RMSE of 1.16\% IV. \textbf  {(b)}~IV smile fit across all four semiconductor tickers as a function of moneyness ($K/S$). The smile shape $(\beta _2, \beta _3, \beta _4)$ was shared from NVDA; only the scalar level $\theta _{\text  {base}}$ was re-fitted per ticker. The shared shape transferred well to AMD (RMSE = 2.34\%) and reasonably to MU (3.99\%) and INTC (4.65\%). \textbf  {(c)}~IV residuals (model $-$ market) by moneyness across all four tickers. Errors were concentrated in the wings ($K/S < 0.85$ and $K/S > 1.15$), with near-ATM residuals below 1\% IV for all tickers.}}{6}{figure.caption.5}\protected@file@percent }
\newlabel{fig:calibration}{{1}{6}{Single-DTE calibration and cross-ticker validation. \textbf {(a)}~NVDA implied volatility smile (DTE~=~80): market calls (blue circles) and puts (coral diamonds) vs.\ the fitted model curve (solid line); the dashed vertical line marks the spot price (\$207). The four-parameter $\psi $ function captured both the put skew and smile curvature with an RMSE of 1.16\% IV. \textbf {(b)}~IV smile fit across all four semiconductor tickers as a function of moneyness ($K/S$). The smile shape $(\beta _2, \beta _3, \beta _4)$ was shared from NVDA; only the scalar level $\theta _{\text {base}}$ was re-fitted per ticker. The shared shape transferred well to AMD (RMSE = 2.34\%) and reasonably to MU (3.99\%) and INTC (4.65\%). \textbf {(c)}~IV residuals (model $-$ market) by moneyness across all four tickers. Errors were concentrated in the wings ($K/S < 0.85$ and $K/S > 1.15$), with near-ATM residuals below 1\% IV for all tickers}{figure.caption.5}{}}
\newlabel{eq:psi_extended}{{11}{6}{Calibration and Validation}{equation.11}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Calibrated $\psi $ parameters from the multi-expiration NVDA dataset. The quadratic DTE term $\beta _5$ captured the U-shaped ATM term structure.}}{6}{table.caption.6}\protected@file@percent }
\newlabel{tab:term_params}{{4}{6}{Calibrated $\psi $ parameters from the multi-expiration NVDA dataset. The quadratic DTE term $\beta _5$ captured the U-shaped ATM term structure}{table.caption.6}{}}
